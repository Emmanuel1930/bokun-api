(function() {
    const API_URL = 'https://api.bokun.io/restapi/v2.0/settings/booking-channel';
    // Replace these with your actual keys
    const ACCESS_KEY = 'YOUR_ACCESS_KEY';
    const SECRET_KEY = 'YOUR_SECRET_KEY';

    async function loadTerms() {
        const termsContainer = document.getElementById('bokun-terms-content');
        
        try {
            const response = await fetch(API_URL, {
                method: 'GET',
                headers: {
                    'X-Bokun-Access-Key': ACCESS_KEY,
                    'X-Bokun-Secret-Key': SECRET_KEY,
                    'Accept': 'application/json'
                }
            });

            if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);

            const data = await response.json();
            
            // Bókun returns the T&C as an HTML string
            if (data && data.termsAndConditions) {
                termsContainer.innerHTML = data.termsAndConditions;
                console.log("📜 Terms & Conditions loaded successfully");
            } else {
                termsContainer.innerHTML = "<p>Terms and conditions are not set in Bókun.</p>";
            }

        } catch (error) {
            console.error("🔥 Error fetching T&Cs:", error);
            termsContainer.innerHTML = "<p>Unable to load Terms at this time.</p>";
        }
    }

    // Run the function
    loadTerms();
})();
