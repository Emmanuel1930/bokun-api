(function() {
    // UPDATED ENDPOINT for v2.0
    const API_URL = 'https://api.bokun.io/restapi/v2.0/marketplace/vendor/self/';
    const ACCESS_KEY = 'YOUR_ACCESS_KEY';
    const SECRET_KEY = 'YOUR_SECRET_KEY';

    async function loadTerms() {
        const termsContainer = document.getElementById('bokun-terms-content');
        
        try {
            const response = await fetch(API_URL, {
                method: 'GET',
                headers: {
                    'X-Bokun-Access-Key': ACCESS_KEY,
                    'X-Bokun-Secret-Key': SECRET_KEY,
                    'Accept': 'application/json'
                }
            });

            if (!response.ok) {
                const errorData = await response.text();
                throw new Error(`HTTP ${response.status}: ${errorData}`);
            }

            const data = await response.json();
            
            // Log the whole data once to see exactly where Bókun put the T&Cs
            console.log("📦 Bókun Self Data:", data);

            // Check for terms in common locations
            const termsHtml = data.termsAndConditions || data.companyPolicies || data.description;
            
            if (termsHtml) {
                termsContainer.innerHTML = termsHtml;
                console.log("📜 Terms found and loaded!");
            } else {
                termsContainer.innerHTML = "<p>Data received, but no Terms & Conditions text found in this field.</p>";
            }

        } catch (error) {
            console.error("🔥 Error:", error);
            termsContainer.innerHTML = `<p>Error: ${error.message}</p>`;
        }
    }

    loadTerms();
})();
